{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@hudson-hustle/game-core": [
        "packages/game-core/src"
      ],
      "@hudson-hustle/game-data": [
        "packages/game-data/src"
      ]
    }
  }
}
