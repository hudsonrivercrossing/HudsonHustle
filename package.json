{
  "name": "hudson-hustle",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @hudson-hustle/web dev",
    "dev:web": "pnpm --filter @hudson-hustle/web dev",
    "dev:server": "pnpm --filter @hudson-hustle/server dev",
    "build": "pnpm --filter @hudson-hustle/game-core build && pnpm --filter @hudson-hustle/game-data build && pnpm --filter @hudson-hustle/server build && pnpm --filter @hudson-hustle/web build",
    "test": "pnpm --filter @hudson-hustle/game-core test && pnpm --filter @hudson-hustle/server test",
    "test:e2e": "pnpm --filter @hudson-hustle/web test:e2e",
    "config:registry": "node scripts/config/generate-config-registry.mjs",
    "config:switch": "node scripts/config/config-switch.mjs",
    "config:preview": "node scripts/config/config-preview.mjs",
    "config:release": "node scripts/config/config-release.mjs",
    "config:export": "pnpm --filter @hudson-hustle/game-data build && node scripts/config/export-current-config.mjs && node scripts/config/generate-config-registry.mjs"
  }
}
